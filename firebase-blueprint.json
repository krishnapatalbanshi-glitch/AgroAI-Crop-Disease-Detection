{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["farmer", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A crop disease detection scan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "diseaseName": { "type": "string" },
        "cropType": { "type": "string" },
        "confidence": { "type": "number" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "treatment": { "type": "string" },
        "prevention": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["userId", "imageUrl", "diseaseName", "confidence", "timestamp", "severity", "cropType"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "scans/{scanId}": {
      "schema": "Scan",
      "description": "History of crop scans"
    }
  }
}
