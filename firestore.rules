// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (UID)
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - createdAt: timestamp
//   - role: string (farmer, admin)
//
// Collection: scans
// Document ID: scanId (auto-generated)
// Fields:
//   - userId: string (required)
//   - imageUrl: string (required)
//   - diseaseName: string (required)
//   - confidence: number (required)
//   - treatment: string
//   - timestamp: timestamp (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "currepted1999@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['farmer', 'admin']);
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'diseaseName', 'confidence', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.imageUrl is string &&
             data.diseaseName is string &&
             data.confidence is number &&
             data.confidence >= 0 && data.confidence <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /scans/{scanId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidScan(request.resource.data);
      allow update: if false; // Scans are immutable for history integrity
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
